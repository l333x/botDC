# ====================================
# Discord Bot - Variables de Entorno
# ====================================
# Copia este archivo como .env y rellena los valores reales.

# Token del bot de Discord (Bot > Token en https://discord.com/developers/applications)
DISCORD_TOKEN=tu_token_aqui

# Client ID de la aplicación (General Information > Application ID)
CLIENT_ID=tu_client_id_aqui

# ID del servidor (Guild) donde registrar los comandos (click derecho en el servidor > Copiar ID)
GUILD_ID=tu_guild_id_aqui

# API Key de Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=tu_api_key_aqui

